{
  "name": "ableton-mcp",
  "version": "0.1.0",
  "description": "Production-grade local Ableton Live MCP server for Windows.",
  "type": "module",
  "bin": {
    "ableton-mcp": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "start": "node dist/src/index.js",
    "start:http": "node dist/src/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "ui-driver": "node dist/scripts/ableton-ui-driver.js",
    "ui-driver:dev": "tsx scripts/ableton-ui-driver.ts",
    "bridge:install": "node dist/scripts/install-ableton-bridge.js --yes",
    "bridge:install:dry-run": "node dist/scripts/install-ableton-bridge.js",
    "bridge:status": "node dist/scripts/bridge-setup-status.js",
    "bridge:setup-listener": "node dist/scripts/ableton-bridge-setup-listener.js",
    "bridge:setup-listener:dev": "tsx scripts/ableton-bridge-setup-listener.ts",
    "inspect": "npx @modelcontextprotocol/inspector --cli node dist/src/index.js --method tools/list",
    "doctor": "node dist/scripts/doctor.js",
    "ready:check": "node dist/scripts/ready-check.js",
    "configure:clients": "node dist/scripts/configure-clients.js",
    "docker:profile:plan": "node dist/scripts/configure-docker-mcp-profile.js --profile hypernimbus",
    "docker:profile:apply": "node dist/scripts/configure-docker-mcp-profile.js --profile hypernimbus --apply",
    "docker:profile:verify": "node dist/scripts/configure-docker-mcp-profile.js --profile hypernimbus --verify",
    "release:check": "node dist/scripts/check-release.js",
    "sweep:safe": "node dist/scripts/safe-sweep.js",
    "sweep:all": "node dist/scripts/tool-contract-sweep.js",
    "live-ready": "node dist/scripts/live-ready.js",
    "live-smoke": "node dist/scripts/live-smoke.js",
    "demo:concept": "node dist/scripts/agent-music-dry-run.js",
    "demo:producer": "node dist/scripts/producer-demo.js",
    "render:occult-liminal": "node scripts/render-occult-liminal.mjs",
    "render:there-was-never-a-door": "node scripts/render-there-was-never-a-door.mjs",
    "render:bad-memory-backrooms": "node scripts/render-bad-memory-backrooms.mjs",
    "render:bad-memory-backrooms:v2": "node scripts/render-bad-memory-backrooms-v2.mjs",
    "render:wallpaper-knows-your-name": "node scripts/render-wallpaper-knows-your-name.mjs",
    "render:infinite-nowhere-protocol": "node scripts/render-infinite-nowhere-protocol.mjs",
    "render:spy-radio-horror": "node scripts/render-spy-radio-horror.mjs",
    "render:blue-food-court-after-midnight": "node scripts/render-blue-food-court-after-midnight.mjs",
    "render:the-road-has-no-horizon": "node scripts/render-the-road-has-no-horizon.mjs",
    "stage:mall-at-the-end-of-sleep:sources": "node scripts/stage-mall-at-the-end-sources.mjs",
    "render:mall-at-the-end-of-sleep": "node scripts/render-mall-at-the-end-of-sleep.mjs",
    "render:the-atrium-below-the-world": "node scripts/render-the-atrium-below-the-world.mjs",
    "self-test": "node dist/scripts/self-test.js",
    "verify:mcp": "node dist/scripts/verify-mcp.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@tonejs/midi": "^2.0.28",
    "fast-glob": "^3.3.3",
    "screenshot-desktop": "^1.15.1",
    "sql.js": "^1.12.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "@types/screenshot-desktop": "^1.12.3",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^4.1.8"
  }
}
