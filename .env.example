# Semicolon-separated. Values cannot widen beyond the built-in platform baseline.
ABLETON_MCP_ALLOWED_ROOTS=
ABLETON_MCP_ENABLE_WRITE=0

# Foreground mouse/keyboard fallback. Background bridge control does not need this.
ABLETON_MCP_ENABLE_UI_CONTROL=0

ABLETON_MCP_ENABLE_DOWNLOADS=0
# Also gates plugin/package download staging. MCP never runs plugin installers.
ABLETON_MCP_BRIDGE_PORT=17364
ABLETON_MCP_UI_DRIVER_PORT=17365
ABLETON_MCP_HTTP_HOST=127.0.0.1
ABLETON_MCP_HTTP_PORT=17366

# Other-device/private-network HTTP mode. Keep disabled unless using Tailscale/VPN or trusted LAN.
ABLETON_MCP_HTTP_ALLOW_REMOTE=0
ABLETON_MCP_HTTP_TOKEN=
ABLETON_MCP_TAILSCALE_HOST=100.84.223.22

# Optional platform/path overrides.
# Windows defaults target Live 12 Trial under C:\ProgramData and Documents\Ableton.
# macOS defaults target /Applications/Ableton Live 12 Trial.app and ~/Music/Ableton.
# Linux/WSL has no native Ableton desktop default; use a Windows/macOS host bridge for live control.
ABLETON_MCP_ABLETON_ROOT=
ABLETON_MCP_LIVE_INSTALL=
ABLETON_MCP_LIVE_EXECUTABLE=
ABLETON_MCP_MAX_EXECUTABLE=
ABLETON_MCP_USER_LIBRARY=
ABLETON_MCP_FACTORY_PACKS=
ABLETON_MCP_LIVE_RECORDINGS=
ABLETON_MCP_PREFERENCES=
ABLETON_MCP_LIVE_DATABASE=
ABLETON_MCP_IMPORTS=

# Optional tool overrides for non-standard installs.
ABLETON_MCP_NODE=
ABLETON_MCP_NPM=
ABLETON_MCP_GIT=
ABLETON_MCP_FFMPEG=
ABLETON_MCP_FFPROBE=
ABLETON_MCP_POWERSHELL=

# Optional, only for Freesound authenticated API access.
FREESOUND_API_KEY=

# Reserved for future authenticated IA work. Current v1 uses unauthenticated read-only metadata/search.
INTERNET_ARCHIVE_ACCESS_KEY=
